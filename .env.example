# Database
DATABASE_URL=postgresql+asyncpg://fineas:fineas@localhost:5432/fineas

# LLM provider: "anthropic" | "openrouter" | "groq"  (default: anthropic)
LLM_PROVIDER=anthropic
# Model override — leave blank to use the provider default
# anthropic default : claude-sonnet-4-6
# openrouter example: anthropic/claude-3.5-sonnet
# groq example      : llama-3.3-70b-versatile
LLM_MODEL=

# Provider API keys — only the key for LLM_PROVIDER needs to be set
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...
GROQ_API_KEY=gsk_...

# Application
APP_ENV=development
LOG_LEVEL=INFO

# Owner auth — password gate for real-data endpoints.
# Just a plaintext password; lives only in this file on the server.
# Session secret: any long random string (e.g. `openssl rand -hex 32`).
FINEAS_OWNER_PASSWORD=
FINEAS_SESSION_SECRET=
FINEAS_SESSION_MAX_AGE=86400

# CORS — must match frontend origin
CORS_ORIGINS=http://localhost:3001

# Projection defaults
DEFAULT_MONTE_CARLO_SIMULATIONS=10000
