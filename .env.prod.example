# Production environment variables for docker-compose.prod.yml
# Copy to .env on the EC2 instance and fill in values.

DOMAIN=<ELASTIC_IP>.nip.io
DB_USER=fineas
DB_PASSWORD=CHOOSE_A_STRONG_PASSWORD
DB_NAME=fineas
CORS_ORIGINS=https://<ELASTIC_IP>.nip.io
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
APP_ENV=production
LOG_LEVEL=INFO

# Owner auth — required in production (fail-fast on boot if missing).
# Generate the hash on your laptop:
#   python scripts/hash_password.py
# Session secret — any long random string, e.g. `openssl rand -hex 32`.
FINEAS_OWNER_PASSWORD_HASH=
FINEAS_SESSION_SECRET=
FINEAS_SESSION_MAX_AGE=86400
